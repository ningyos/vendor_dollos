# DollOS Service SELinux policy
# Currently runs as system_app domain (default for sharedUserId=system + platform cert)
# Custom dollos_service domain deferred until system sepolicy integration
#
# When ready to use custom domain, uncomment and move to system/sepolicy/private/:
# type dollos_service, domain;
# app_domain(dollos_service)
# net_domain(dollos_service)
# allow dollos_service dollos_data_file:dir create_dir_perms;
# allow dollos_service dollos_data_file:file create_file_perms;
# binder_use(dollos_service)
# binder_service(dollos_service)
# allow dollos_service app_api_service:service_manager find;
